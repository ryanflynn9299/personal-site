{
  "name": "personal-site3",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "prebuild": "node -e \"if (!require('fs').existsSync('node_modules/typescript')) { console.error('TypeScript not found. Run pnpm install first.'); process.exit(1); }\"",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "build:webpack": "next build",
    "start": "next start",
    "lint": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "lint:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out .turbo node_modules/.cache",
    "validate": "pnpm run type-check && pnpm run lint && pnpm run eslint",
    "prepare": "echo 'Run pnpm run validate before committing'",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm run test && pnpm run test:e2e"
  },
  "dependencies": {
    "@directus/sdk": "^16.1.0",
    "@floating-ui/react": "^0.27.16",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@tabler/icons-react": "^3.36.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.19.1",
    "gsap": "^3.13.0",
    "lucide-react": "^0.556.0",
    "motion": "^12.23.26",
    "next": "^16.0.7",
    "ogl": "^1.0.11",
    "phosphor-react": "^1.4.1",
    "pino": "^10.0.0",
    "postprocessing": "^6.38.2",
    "radix-ui": "^1.4.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-force-graph-2d": "^1.29.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remixicon": "^4.7.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.182.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "node-gyp": "^11.2.0",
    "pino-pretty": "^13.1.2",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
