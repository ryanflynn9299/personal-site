# ==============================================================================
# Environment Variables Example
# ==============================================================================
# This file contains all environment variables used by the project and Docker services.
# Copy this file to .env and fill in your actual values.
# 
# IMPORTANT: Never commit .env to version control - it contains secrets!
# This .env.example file is safe to commit as it contains no real values.
# ==============================================================================

# ==============================================================================
# Next.js Frontend Application
# ==============================================================================

# Directus CMS Configuration
# These are REQUIRED for blog functionality. If not set, blog pages will fail.
# 
# NEXT_PUBLIC_DIRECTUS_URL: Public URL accessible from the browser
#   - Used for client-side image loading and asset URLs
#   - Example: http://localhost:8055 (dev) or https://cms.yourdomain.com (prod)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# DIRECTUS_URL_SERVER_SIDE: Internal URL for server-side requests
#   - Used for server-side data fetching (blog posts, etc.)
#   - In Docker: http://ps-directus:8055
#   - Local dev: http://localhost:8055
#   - Production: http://ps-directus:8055 or internal URL
DIRECTUS_URL_SERVER_SIDE=http://ps-directus:8055

# Matomo Analytics Configuration (OPTIONAL)
# These gate Matomo analytics functionality. If not set, analytics will be disabled.
# Set to "DISABLED" to explicitly disable, or leave empty to disable silently.
# 
# NEXT_PUBLIC_MATOMO_URL: Matomo instance URL
#   - Example: http://localhost (dev) or https://analytics.yourdomain.com (prod)
#   - In Docker: http://ps-matomo:80
NEXT_PUBLIC_MATOMO_URL=DISABLED

# NEXT_PUBLIC_MATOMO_SITE_ID: Matomo site ID
#   - Found in Matomo admin panel after creating a site
#   - Example: 1
NEXT_PUBLIC_MATOMO_SITE_ID=DISABLED

# Node Environment (automatically set by Next.js, but can be overridden)
# Options: development, production, test
# NODE_ENV=development

# ==============================================================================
# Directus CMS Service
# ==============================================================================

# Directus Security Keys
# Generate secure random strings for these (minimum 32 characters recommended)
# Use: openssl rand -hex 32
DIRECTUS_KEY=your-directus-key-here-minimum-32-characters-long
DIRECTUS_SECRET=your-directus-secret-here-minimum-32-characters-long

# Database Configuration (PostgreSQL)
# These must match the ps-database service configuration
DB_PORT=5432
DB_NAME=directus
DB_USER=directus
DB_PASSWORD=your-secure-database-password-here

# Directus Admin Account
# Initial admin user created on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PW=your-secure-admin-password-here

# Public URL for Directus
# Used for CORS and public asset URLs
# Example: http://localhost:8055 (dev) or https://cms.yourdomain.com (prod)
HTTP_DOMAIN_NAME=http://localhost:8055

# ==============================================================================
# Matomo Analytics Service
# ==============================================================================

# Matomo Database Passwords
# Generate secure random strings for these
# Use: openssl rand -hex 32
MATOMO_DB_PASSWORD=your-matomo-db-password-here
MATOMO_DB_ROOT_PASSWORD=your-matomo-db-root-password-here

# ==============================================================================
# Code Sync Service (Optional)
# ==============================================================================

# GitHub Repository
# Format: username/repository-name
# Example: yourusername/personal-site
# Leave empty to disable sync service
GITHUB_REPO=

# Sync Configuration
SYNC_BRANCH=main
SYNC_MODE=poll
# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300

# Webhook Configuration (only needed if SYNC_MODE=webhook)
# Generate secure random strings for these
# Use: openssl rand -hex 32
WEBHOOK_SECRET=
SYNC_ADMIN_TOKEN=

# ==============================================================================
# Notes
# ==============================================================================
#
# 1. Required Variables for Basic Functionality:
#    - NEXT_PUBLIC_DIRECTUS_URL
#    - DIRECTUS_URL_SERVER_SIDE
#    - DIRECTUS_KEY
#    - DIRECTUS_SECRET
#    - DB_NAME, DB_USER, DB_PASSWORD
#    - ADMIN_EMAIL, ADMIN_PW
#    - HTTP_DOMAIN_NAME
#
# 2. Optional Variables (Gate Functionality):
#    - NEXT_PUBLIC_MATOMO_URL / NEXT_PUBLIC_MATOMO_SITE_ID (set to "DISABLED" or leave empty)
#    - GITHUB_REPO (leave empty to disable sync service)
#
# 3. Security Best Practices:
#    - Use strong, unique passwords for all services
#    - Generate secrets using: openssl rand -hex 32
#    - Never commit .env to version control
#    - Rotate secrets periodically
#
# 4. Docker Network:
#    - Ensure 'backend-net' network exists: docker network create backend-net
#    - All services communicate via this network
#
# 5. Development vs Production:
#    - Development: Use localhost URLs
#    - Production: Use service names (ps-directus, ps-matomo) for internal communication
#    - Use public domains for NEXT_PUBLIC_ variables in production
# ==============================================================================
