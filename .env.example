# ==============================================================================
# Application Configuration
# ==============================================================================

# Application mode: production | live-dev | offline-dev | test
# - production: Services required, errors are real errors
# - live-dev: Services required, dev environment (default: dev UI enabled)
# - offline-dev: Services disabled, pure frontend dev (default)
# - test: Services disabled, test mode (auto-set in tests)
APP_MODE=offline-dev

# Dev mode UI toggle: true | false
# Controls unreleased UI features (independent of service connectivity)
# Default: true in dev modes, false in production/test
DEV_MODE_UI=true

# Site URL (used for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.ryanflynn.org

# Enable pretty-printed logs in development
ENABLE_PINO_PRETTY=false

# ==============================================================================
# Directus CMS
# ==============================================================================

# Public URL (accessible from browser, used for images/assets)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Internal URL (server-side requests, Docker service name or localhost)
DIRECTUS_URL_SERVER_SIDE=http://ps-directus:8055

# Directus Security Keys (generate: openssl rand -hex 32)
DIRECTUS_KEY=your-directus-key-here-minimum-32-characters-long
DIRECTUS_SECRET=your-directus-secret-here-minimum-32-characters-long

# Database Configuration (PostgreSQL)
DB_PORT=5432
DB_NAME=directus
DB_USER=directus
DB_PASSWORD=your-secure-database-password-here

# Directus Admin Account (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PW=your-secure-admin-password-here

# Public URL for Directus (CORS and public asset URLs)
HTTP_DOMAIN_NAME=http://localhost:8055

# ==============================================================================
# SMTP Email Service
# ==============================================================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=contact@example.com
SMTP_TO=your-email@example.com

# Optional SMTP Authentication
SMTP_USER=
SMTP_PASS=

# ==============================================================================
# Matomo Analytics (Optional)
# ==============================================================================

# Set to "DISABLED" or leave empty to disable
NEXT_PUBLIC_MATOMO_URL=DISABLED
NEXT_PUBLIC_MATOMO_SITE_ID=DISABLED

# Matomo Database Passwords (generate: openssl rand -hex 32)
MATOMO_DB_PASSWORD=your-matomo-db-password-here
MATOMO_DB_ROOT_PASSWORD=your-matomo-db-root-password-here

# ==============================================================================
# Code Sync Service (Optional)
# ==============================================================================

# GitHub Repository (format: username/repo, leave empty to disable)
GITHUB_REPO=

SYNC_BRANCH=main
SYNC_MODE=poll
POLL_INTERVAL=300

# Webhook Configuration (only if SYNC_MODE=webhook)
WEBHOOK_SECRET=
SYNC_ADMIN_TOKEN=

# ==============================================================================
# Cloudflare Tunnel (Optional)
# ==============================================================================

# Cloudflare Tunnel Token (get from Cloudflare Zero Trust dashboard)
# Alternative: Use config file at ./cloudflare/config.yml
CLOUDFLARE_TUNNEL_TOKEN=
