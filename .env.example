# ==============================================================================
# Application Runtime
# ==============================================================================

# Runtime mode: production | live-dev | offline-dev | test
# - production:  Services required, errors are real errors
# - live-dev:    Services required, dev environment (mirrors production behavior)
# - offline-dev: Services disabled, pure frontend development (default)
# - test:        Services disabled, test mode (auto-set by test runners)
RUNTIME_MODE=offline-dev

# Preview features toggle: true | false
# Controls visibility of unreleased UI features (independent of service connectivity)
# Default: true in dev modes, false in production/test
ENABLE_PREVIEW_FEATURES=true

# Canonical site URL (used for SEO, sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.ryanflynn.org

# Pretty-print logs in development (uses pino-pretty transport)
LOG_PRETTY_PRINT=false

# ==============================================================================
# Directus CMS
# ==============================================================================

# Public URL (accessible from browser — used for images, assets, admin links)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Internal URL (server-side requests — Docker service name or localhost)
DIRECTUS_INTERNAL_URL=http://ps-directus:8055

# Directus application keys (generate: openssl rand -hex 32)
DIRECTUS_KEY=your-directus-key-here-minimum-32-characters-long
DIRECTUS_SECRET=your-directus-secret-here-minimum-32-characters-long

# Directus admin account (created on first startup)
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=your-secure-admin-password-here

# Directus public URL for CORS and asset URLs (used by the Directus container)
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Directus CORS — leave false unless a browser client calls the Directus API
# directly (the Next.js frontend talks to Directus server-side only)
DIRECTUS_CORS_ENABLED=false

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================

DB_PORT=5432
DB_NAME=directus
DB_USER=directus
DB_PASSWORD=your-secure-database-password-here

# ==============================================================================
# Admin Dashboard
# ==============================================================================

# Passcode for admin dashboard login (minimum 8 characters — enforced at startup)
ADMIN_PASSCODE=your-admin-passcode-here

# Session secret for signing admin session tokens (minimum 32 characters —
# enforced at startup; generate: openssl rand -hex 32)
ADMIN_SESSION_SECRET=your-session-secret-here

# Require Tailscale VPN for admin access (production hardening)
ADMIN_REQUIRE_TAILSCALE=false

# ==============================================================================
# SMTP Email Service
# ==============================================================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=contact@example.com
SMTP_TO=your-email@example.com

# Optional SMTP authentication
SMTP_USER=
SMTP_PASS=

# ==============================================================================
# Matomo Analytics (required at launch — self-hosted)
# ==============================================================================
# Public URL reachable from the browser (not the Docker internal hostname).
# Example: https://analytics.ryanflynn.org
NEXT_PUBLIC_MATOMO_URL=https://your-matomo-public-url.example.com
NEXT_PUBLIC_MATOMO_SITE_ID=1

# Set both to DISABLED only for local offline development without analytics.
# NEXT_PUBLIC_MATOMO_URL=DISABLED
# NEXT_PUBLIC_MATOMO_SITE_ID=DISABLED

# Matomo database passwords (generate: openssl rand -hex 32)
MATOMO_DB_PASSWORD=your-matomo-db-password-here
MATOMO_DB_ROOT_PASSWORD=your-matomo-db-root-password-here

# ==============================================================================
# Cloudflare (Optional)
# ==============================================================================

# Cloudflare Access tunnel for dev mode (only used in live-dev)
CF_TUNNEL_ENABLED=false
CF_ACCESS_CLIENT_ID=your-client-id
CF_ACCESS_CLIENT_SECRET=your-client-secret

# Cloudflare Tunnel token (get from Cloudflare Zero Trust dashboard)
CF_TUNNEL_TOKEN=

# ==============================================================================
# Code Sync Service (Optional — currently disabled)
# ==============================================================================

# GitHub repository (format: username/repo, leave empty to disable)
SYNC_GITHUB_REPO=
SYNC_BRANCH=main
SYNC_MODE=poll
POLL_INTERVAL=300

# Webhook configuration (only if SYNC_MODE=webhook)
WEBHOOK_SECRET=
SYNC_ADMIN_TOKEN=
