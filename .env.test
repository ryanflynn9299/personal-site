# Test Environment Variables
# These values are used when running tests (unit, integration, e2e)
# They provide safe defaults that don't connect to real services

# Disable analytics in tests
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# Public contact email for contact page tests
NEXT_PUBLIC_CONTACT_EMAIL=ryan.flynn001@gmail.com

# Directus CMS — not required for tests (graceful degradation)
NEXT_PUBLIC_DIRECTUS_URL=
DIRECTUS_INTERNAL_URL=

# Email service — disabled in tests
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
